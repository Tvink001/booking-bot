# =============================================================================
# Booking Bot — .env.example  (committed; reference for the real .env)
# Single source of truth for variables: project_specs.md §3.1
# Tags on each variable show where it's actually used:
#   [both]            — needed locally AND on Railway
#   [local-only]      — only matters when MODE=polling (dev machine)
#   [production-only] — only matters when MODE=webhook (Railway)
# =============================================================================

# --- TELEGRAM ----------------------------------------------------------------

# [both] Bot token from @BotFather. Dev bot for local, prod bot for Railway.
BOT_TOKEN=123456789:AAA-BBB-CCC-replace-with-real-token-from-BotFather

# [production-only] X-Telegram-Bot-Api-Secret-Token validator. Generate via:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# pydantic-settings requires the field non-empty even locally, so set ANY value
# locally (placeholder is fine) — it's not consulted in polling mode.
WEBHOOK_SECRET=replace-with-32+char-random-string

# [production-only] Public HTTPS URL Railway assigns to the service.
# Locally keep the placeholder — pydantic just needs the field non-empty.
# After first Railway deploy, copy the assigned domain into Railway Variables.
WEBHOOK_BASE_URL=https://your-app.up.railway.app

# [both] Negative chat_id (group) or positive user_id (DM) where owner gets
# new-booking notifications. Find via @getmyidbot inside the target chat.
OWNER_TELEGRAM_CHAT_ID=-1001234567890

# [both] Comma-separated Telegram user IDs allowed to run /today /week /stats
# /export. Usually your own ID. Get via DM to @getmyidbot.
ADMIN_TELEGRAM_IDS=123456789

# --- GOOGLE (Sheets + Calendar) ----------------------------------------------

# [both] Path to the service-account JSON key.
#   Locally:  ./secrets/credentials.json
#   Railway:  /app/secrets/credentials.json  (Railway Secret File mount)
GOOGLE_SERVICE_ACCOUNT_PATH=./secrets/credentials.json

# [both] Spreadsheet ID from the Sheets URL between /d/ and /edit
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789ABCDE

# [both] Default IANA timezone for booking datetimes and Calendar events.
GOOGLE_CALENDAR_DEFAULT_TZ=Europe/Kyiv

# --- GROQ (WOW 3: voice input via Whisper-Large-v3-turbo) --------------------

# [both, optional until WOW 3] gsk_... API key from console.groq.com.
# Free tier; permanent — no card. Required for §17 voice handler only.
GROQ_API_KEY=gsk_replace_with_real_key_from_console_groq_com

# --- MODE & WEB SERVER -------------------------------------------------------

# [both] polling (local dev) or webhook (Railway). Locally always polling.
MODE=polling

# [production-only] aiohttp bind host/port for webhook mode. Ignored locally.
WEB_HOST=0.0.0.0
WEB_PORT=8080

# --- SCHEDULER (APScheduler 4 + SQLite + aiosqlite) --------------------------

# [production-only] When set, overrides SCHEDULER_DB_PATH with a full SQLAlchemy
# URL. Used for managed Postgres (Koyeb + Neon free tier — no persistent disk
# needed because state lives in Neon). Local dev leaves this UNSET.
# Form: postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME?sslmode=require
# Neon's pooled connection string fits directly; just swap the leading
# "postgresql://" for "postgresql+asyncpg://".
SCHEDULER_DB_URL=

# [both] SQLite fallback path for the AsyncScheduler data store. Ignored when
# SCHEDULER_DB_URL is set.
#   Locally:  ./data/scheduler.db
#   Railway:  /app/data/scheduler.db  (mounted persistent volume)
SCHEDULER_DB_PATH=./data/scheduler.db

# [both] Timezone for CronTrigger / DateTrigger.
SCHEDULER_TIMEZONE=Europe/Kyiv

# --- LOGGING -----------------------------------------------------------------

# [both] DEBUG | INFO | WARNING | ERROR. Locally INFO; prod can lift to WARNING.
LOG_LEVEL=INFO
