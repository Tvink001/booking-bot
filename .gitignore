# =============================================================================
# Booking Bot — .gitignore
# Guards secrets and local artefacts. After a fresh clone, `git status` should
# not list .env, secrets/credentials.json, or data/scheduler.db.
# =============================================================================

# --- Secrets — NEVER commit ---------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.development

# Google service account JSON and any other keys under secrets/
secrets/*
!secrets/README.md

# --- Runtime data (Railway persistent volume) ---------------------------
data/*
!data/.gitkeep

# --- Logs ---------------------------------------------------------------
*.log
logs/

# --- Python -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/
pip-log.txt
pip-delete-this-directory.txt
.coverage
.coverage.*
htmlcov/

# --- IDE / editors ------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# --- OS junk ------------------------------------------------------------
Thumbs.db
desktop.ini
$RECYCLE.BIN/
